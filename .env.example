# A900 数字人问答 —— 环境变量模板
# 实际值写进 .env.local（已 gitignore，绝不提交）。值可从 A400 / A200 的 .env.local 复制。

# 后端 API 端口（避开 vite 端口与其它项目）
API_PORT=4009

# ── 讯飞星火 LLM（问答）──
# 主链路（maas-coding 端点）
IFLYTEK_API_KEY=             # 格式 api-key:api-secret
IFLYTEK_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
IFLYTEK_MODEL=astron-code-latest
# 兜底链路（maas 通用端点，主模型失败时用）
IFLYTEK_FALLBACK_API_KEY=
IFLYTEK_FALLBACK_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2
IFLYTEK_FALLBACK_MODEL=xop35qwen2b

# ── 豆包 / 火山引擎 TTS（语音播报）──
VOLC_TTS_APP_KEY=
VOLC_TTS_ACCESS_KEY=
VOLC_TTS_SPEAKER=zh_female_vv_uranus_bigtts

# ── 火山 ASR（语音识别，复用上面同一对 TTS 密钥，无需另填）──
# 大模型录音识别端点资源 ID，一般留空用默认；如火山控制台分配了别的资源再覆盖
VOLC_ASR_RESOURCE_ID=volc.bigasr.auc_turbo

# ── 微信公众号（JS-SDK 网页分享卡片）──
# 留空 → fake 模式：本地/无配置时分享接口返回占位、不报错（微信卡片不生效）。
# 与 ATA100 同域名(h100.jsai100.com)同服务器，可直接复用 ATA100 的同一对公众号凭证；
# 公众号后台「JS接口安全域名」「IP 白名单」已为该域名配过，A900 无需再配。
WECHAT_OFFICIAL_ACCOUNT_APPID=
WECHAT_OFFICIAL_ACCOUNT_SECRET=
